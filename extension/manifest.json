{
  "manifest_version": 3,
  "name": "Israeli Vault Autofill POC",
  "version": "1.2.0",
  "description": "Local demo autofill proof of concept only",
  "minimum_chrome_version": "93",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://www.htzone.co.il/*",
    "https://htzone.co.il/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "generic/form-detector.js",
        "generic/field-mapper.js",
        "generic/fill-executor.js",
        "generic/generic-autofill.js",
        "mappings.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  }
}
